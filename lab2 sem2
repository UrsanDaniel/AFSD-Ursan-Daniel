import csv
import os
glosar = {}

def adauga_termen():
    termen = input("Introduceți termenul nou: ").strip().lower()
    if termen in glosar:
        print(f"Eroare: Termenul '{termen}' există deja în glosar.")
        return

    definitie = input("Definiție: ")
    categorie = input("Categorie: ")
    exemplu = input("Exemplu: ")

    glosar[termen] = {
        "definiție": definitie,
        "categorie": categorie,
        "exemplu": exemplu  
    }
    print("Termenul a fost adăugat cu succes!")
    
def cautare_exacta():
    termen = input("Introduceți termenul căutat: ").strip().lower()
    if termen in glosar:
        info = glosar[termen]
        print(f"\n--- {termen.upper()} ---")
        print(f"Definiție: {info['definiție']}")
        print(f"Categorie: {info['categorie']}")
        print(f"Exemplu: {info['exemplu']}")
    else:
        print("Termenul nu a fost găsit.")

def cautare_fragment():
    fragment = input("Introduceți fragmentul de text: ").strip().lower()
    gasit = False
    for termen, info in glosar.items():
        if fragment in termen or fragment in info['definiție']:
            print(f"- {termen}: {info['definiție']}")
            gasit = True
    if not gasit:
        print("Nu s-au găsit termeni care să conțină acest fragment.")

def actualizare_termen():
    termen = input("Ce termen doriți să actualizați? ").strip().lower()
    if termen in glosar:
        print("Ce doriți să modificați? (definiție / categorie / exemplu)")
        camp = input("Opțiune: ").strip().lower()
        
        if camp in glosar[termen]:
            valoare_noua = input(f"Introduceți noua valoare pentru {camp}: ")
            glosar[termen][camp] = valoare_noua
            print("Actualizare reușită!")
        else:
            print("Câmp invalid.")
    else:
        print("Termenul nu există.")

def sterge_termen():
    termen = input("Introduceți termenul pentru ștergere: ").strip().lower()
    if termen in glosar:
        del glosar[termen]
        print(f"Termenul '{termen}' a fost șters.")
    else:
        print("Termenul nu a fost găsit.")

def afisare_completa():
    if not glosar:
        print("Glosarul este gol.")
        return
    
    print("\n--- TOȚI TERMENII ---")
    for termen, info in glosar.items():
        print(f"[{termen.capitalize()}] | Cat: {info['categorie']} | Def: {info['definiție']}")

def afisare_statistici():
    total = len(glosar)
    print(f"\nNumăr total de termeni: {total}")
    
    categorii = {}
    for info in glosar.values():
        cat = info['categorie']
        categorii[cat] = categorii.get(cat, 0) + 1
    
    print("Termeni pe categorii:")
    for cat, count in categorii.items():
        print(f" - {cat}: {count}")

def salveaza_csv():
    nume_fisier = "glosar.csv"
    try:
        with open(nume_fisier, 'w', newline='', encoding='utf-8') as f:
            writer = csv.writer(f)
            # Header
            writer.writerow(["termen", "definitie", "categorie", "exemplu"])
            for termen, info in glosar.items():
                writer.writerow([termen, info['definiție'], info['categorie'], info['exemplu']])
        print(f"Datele au fost salvate în {nume_fisier}.")
    except Exception as e:
        print(f"Eroare la salvare: {e}")

def incarca_csv():
    nume_fisier = "glosar.csv"
    if not os.path.exists(nume_fisier):
        print("Nu există niciun fișier de date anterior.")
        return

    try:
        global glosar
        glosar = {} 
        with open(nume_fisier, 'r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            for row in reader:
                glosar[row['termen']] = {
                    "definiție": row['definitie'],
                    "categorie": row['categorie'],
                    "exemplu": row['exemplu']
                }
        print("Datele au fost încărcate cu succes!")
    except Exception as e:
        print(f"Eroare la încărcare: {e}")

def meniu():
    while True:
        print("\n--- MENIU GLOSAR INTERACTIV ---")
        print("1. Adăugare termen")
        print("2. Căutare exactă")
        print("3. Căutare după fragment")
        print("4. Actualizare termen")
        print("5. Ștergere termen")
        print("6. Afișare completă")
        print("7. Statistici")
        print("8. Salvare în CSV")
        print("9. Încărcare din CSV")
        print("0. Ieșire")
        
        optiune = input("Alegeți o opțiune: ")

        if optiune == '1': adauga_termen()
        elif optiune == '2': cautare_exacta()
        elif optiune == '3': cautare_fragment()
        elif optiune == '4': actualizare_termen()
        elif optiune == '5': sterge_termen()
        elif optiune == '6': afisare_completa()
        elif optiune == '7': afisare_statistici()
        elif optiune == '8': salveaza_csv()
        elif optiune == '9': incarca_csv()
        elif optiune == '0': 
            print("La revedere!")
            break
        else:
            print("Opțiune invalidă. Încercați din nou.")

if __name__ == "__main__":
    meniu()
